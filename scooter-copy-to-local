#!/usr/bin/env bash
#
# Copy files from kubernetes pod to local directory
# Usage: k8s-copy-to-local <remote-path> <local-path>
#
# Copy a file to the current directory
# Example: k8s-copy-to-local /app/tmp/logs/app.log app.log
#
# Copy to directory relative to the current directory
# Example: k8s-copy-to-local /app/tmp/logs/app.log tmp/app.log

# Configuration - set these environment variables or modify defaults
SERVICE_NAME="${SERVICE_NAME:-app-server}"
SERVICE_LABEL="${SERVICE_LABEL:-service=${SERVICE_NAME}}"
ROLE_LABEL="${ROLE_LABEL:-role=app-server}"
NAMESPACE="${NAMESPACE:-default}"

context=$(kubectl config current-context)
namespace=$(kubectl config view | grep namespace | cut -d ":" -f 2 | awk NF)
namespace="${namespace:-$NAMESPACE}"

pod=$(kubectl get pods -l "${SERVICE_LABEL},${ROLE_LABEL}" -o custom-columns=":metadata.name" | awk NF)
remote="${namespace}/${pod}:${1}"

copy_command="kubectl --context $context -n ${namespace} cp ${remote} ${PWD}/${2}"
echo $copy_command
$copy_command

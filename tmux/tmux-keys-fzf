#!/usr/bin/env zsh
# Display all tmux keybindings in a searchable fzf popup.
# Invoked via: prefix + ?

tmux list-keys 2>/dev/null \
  | sed 's/bind-key[[:space:]]*//' \
  | awk '{
    flags = ""; table = "prefix"; i = 1
    while (i <= NF) {
      if ($i == "-r") { flags = flags "(r) "; i++; continue }
      if ($i == "-T") { table = $(i+1); i+=2; continue }
      if ($i == "-N") { i+=2; continue }
      break
    }
    key = $i; i++
    cmd = ""
    for (; i <= NF; i++) cmd = cmd (cmd ? " " : "") $i
    if (length(cmd) > 80) cmd = substr(cmd, 1, 77) "..."
    printf "%-20s  %-20s  %s%s\n", table, key, flags, cmd
  }' \
  | sort -k1,1 -k2,2 \
  | fzf \
      --no-sort \
      --delimiter '  ' \
      --nth 2.. \
      --style full \
      --reverse \
      --border-label " tmux keybindings " \
      --input-label " search " \
      --padding 0,1 \
      --prompt "" \
      --color "bg:#282828,bg+:#3c3836" \
      --color "fg:#ebdbb2,fg+:#ebdbb2" \
      --color "hl:#928374,hl+:#fabd2f" \
      --color "border:#504945,label:#a89984" \
      --color "prompt:#fabd2f,pointer:#fe8019,marker:#fe8019" \
      --color "header:#928374:italic,info:#8ec07c" \
      --color "input-border:#689d6a,input-label:#8ec07c" \
      --bind "esc:abort,q:abort,enter:abort"

#!/bin/bash

# Refresh Jira ticket cache using MCP tools
# This script should be run BY CLAUDE CODE using the Jira MCP tools
#
# Usage: jira-cache-refresh [--scope my|all]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${HOME}/.config/jira-select"
CONFIG_FILE="${CONFIG_DIR}/config.yml"
PROJECTS_FILE="${CONFIG_DIR}/projects.txt"
CACHE_DIR="${HOME}/.cache/jira-tickets"

mkdir -p "$CACHE_DIR" "$CONFIG_DIR"

# Parse arguments
SCOPE="my"  # "my" or "all"

while [[ $# -gt 0 ]]; do
    case $1 in
        --scope)
            SCOPE="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# Check if config exists
if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
# Jira Ticket Selector Configuration

# Your Jira username (email)
username: user@example.com

# Cache TTL in minutes
cache_ttl_minutes: 30
EOF
    echo "Created default config at $CONFIG_FILE"
fi

# Check if projects are configured
if [[ ! -f "$PROJECTS_FILE" ]] || [[ ! -s "$PROJECTS_FILE" ]]; then
    echo "No Jira projects configured."
    echo "Creating default projects file at $PROJECTS_FILE"
    echo "GROWTH" > "$PROJECTS_FILE"
    echo "Please edit $PROJECTS_FILE to add your Jira project keys (one per line)"
fi

# Read projects
PROJECTS=($(cat "$PROJECTS_FILE"))

if [[ ${#PROJECTS[@]} -eq 0 ]]; then
    echo "No projects configured in $PROJECTS_FILE"
    exit 1
fi

# Build cache key
CACHE_KEY="${SCOPE}-$(echo "${PROJECTS[@]}" | tr ' ' '-')"
CACHE_FILE="${CACHE_DIR}/${CACHE_KEY}.json"

# Build JQL based on scope
if [[ "$SCOPE" == "my" ]]; then
    # My assigned tickets
    PROJECT_JQL=$(printf "project = %s" "${PROJECTS[0]}")
    for ((i=1; i<${#PROJECTS[@]}; i++)); do
        PROJECT_JQL="$PROJECT_JQL OR project = ${PROJECTS[i]}"
    done
    JQL="($PROJECT_JQL) AND assignee = currentUser() AND resolution = Unresolved ORDER BY updated DESC"
else
    # All tickets in projects
    PROJECT_JQL=$(printf "project = %s" "${PROJECTS[0]}")
    for ((i=1; i<${#PROJECTS[@]}; i++)); do
        PROJECT_JQL="$PROJECT_JQL OR project = ${PROJECTS[i]}"
    done
    JQL="($PROJECT_JQL) AND resolution = Unresolved ORDER BY updated DESC"
fi

echo "Fetching Jira tickets for scope: $SCOPE"
echo "Projects: ${PROJECTS[*]}"
echo "JQL: $JQL"
echo ""

# Output instructions for Claude
cat <<EOF
===============================================================================
CLAUDE: Please use the Jira MCP tools to fetch these tickets.

Run: mcp__atlassian-mcp__jira_search
Parameters:
  jql: "$JQL"
  fields: "summary,status,assignee,priority,issuetype,created,updated,project"
  limit: 100

Then save the result JSON to: $CACHE_FILE

The JSON should contain an "issues" array with issue objects.
Each issue should have "key" and "fields" properties.
===============================================================================
EOF

echo ""
echo "Waiting for Claude to fetch tickets..."
echo "Cache file: $CACHE_FILE"

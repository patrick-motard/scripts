{
  "manifest_version": 2,
  "name": "Tab Search Host",
  "version": "1.0",
  "description": "Exposes open tabs to native messaging host for Hammerspoon integration",
  "permissions": [
    "tabs",
    "bookmarks",
    "nativeMessaging"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-search-host@local",
      "strict_min_version": "78.0"
    }
  }
}

#!/usr/bin/env zsh

usage="NAME
      terminal-theme-picker - interactively switch alacritty + tmux + neovim themes in real time

SYNOPSIS
      terminal-theme-picker [-h]

DESCRIPTION
      Opens an fzf picker showing available themes. Previewing a theme applies it
      live to alacritty, tmux, and all running neovim instances. Confirming saves
      the selection. Cancelling (ESC/Ctrl-C) restores the previous theme.

      Themes live in ~/.config/alacritty/themes/ and ~/.config/tmux/themes/.
      The current selection is stored in ~/.local/share/theme-picker/current
      (machine-local, not tracked in git).

ARGUMENTS
      -h, --help
          Show this help message.

EXAMPLES
      terminal-theme-picker
      # bind in tmux: bind-key T display-popup -E -w 60% -h 70% 'terminal-theme-picker'
"

ALACRITTY_THEMES_DIR="$HOME/.config/alacritty/themes"
TMUX_THEMES_DIR="$HOME/.config/tmux/themes"
CURRENT_THEME_FILE="$HOME/.local/share/theme-picker/current"
ALACRITTY_CURRENT="$HOME/.config/alacritty/current-theme.toml"
TMUX_CURRENT="$HOME/.config/tmux/themes/current-theme.conf"
THEMERY_STATE="$HOME/.local/share/nvim-custom/themery/state.json"

while (( $# > 0 )); do
    case "$1" in
    -h | --help)
        echo "$usage"
        exit 0
        ;;
    -*)
        echo "Unknown option: $1" >&2
        echo "$usage" >&2
        exit 1
        ;;
    *)
        break
        ;;
    esac
done

# Map terminal theme name → nvim colorscheme + optional before lua code
nvim_theme_for() {
    local theme="$1"
    case "$theme" in
    gruvbox-dark)           echo "gruvbox" "vim.opt.background = 'dark'" ;;
    gruvbox-dark-hard)      echo "gruvbox" "vim.opt.background = 'dark'" ;;
    gruvbox-dark-soft)      echo "gruvbox" "vim.opt.background = 'dark'" ;;
    gruvbox-material)       echo "gruvbox-material" "vim.opt.background = 'dark'\nvim.g.gruvbox_material_background = 'medium'" ;;
    gruvbox-material-hard)  echo "gruvbox-material" "vim.opt.background = 'dark'\nvim.g.gruvbox_material_background = 'hard'" ;;
    gruvbox-material-soft)  echo "gruvbox-material" "vim.opt.background = 'dark'\nvim.g.gruvbox_material_background = 'soft'" ;;
    nord)                   echo "nordic" "" ;;
    nordic)                 echo "nordic" "" ;;
    kanagawa-wave)          echo "kanagawa-wave" "" ;;
    kanagawa-dragon)        echo "kanagawa-dragon" "" ;;
    everforest-hard)        echo "everforest" "vim.opt.background = 'dark'\nvim.g.everforest_background = 'hard'" ;;
    everforest-medium)      echo "everforest" "vim.opt.background = 'dark'\nvim.g.everforest_background = 'medium'" ;;
    everforest-soft)        echo "everforest" "vim.opt.background = 'dark'\nvim.g.everforest_background = 'soft'" ;;
    darkearth)              echo "darkearth" "" ;;
    tokyo-night)            echo "tokyonight-night" "" ;;
    tokyonight-storm)       echo "tokyonight-storm" "" ;;
    tokyonight-moon)        echo "tokyonight-moon" "" ;;
    *)                      echo "" "" ;;
    esac
}

# Send colorscheme to all running nvim instances
nvim_apply_theme() {
    local theme="$1"
    local cmd
    case "$theme" in
    gruvbox-dark)          cmd=":lua require('gruvbox').setup({contrast=''})<CR>:set background=dark<CR>:colorscheme gruvbox<CR>" ;;
    gruvbox-dark-hard)     cmd=":lua require('gruvbox').setup({contrast='hard'})<CR>:set background=dark<CR>:colorscheme gruvbox<CR>" ;;
    gruvbox-dark-soft)     cmd=":lua require('gruvbox').setup({contrast='soft'})<CR>:set background=dark<CR>:colorscheme gruvbox<CR>" ;;
    gruvbox-material)      cmd=":let g:gruvbox_material_background='medium'<CR>:set background=dark<CR>:colorscheme gruvbox-material<CR>" ;;
    gruvbox-material-hard) cmd=":let g:gruvbox_material_background='hard'<CR>:set background=dark<CR>:colorscheme gruvbox-material<CR>" ;;
    gruvbox-material-soft) cmd=":let g:gruvbox_material_background='soft'<CR>:set background=dark<CR>:colorscheme gruvbox-material<CR>" ;;
    nord)                  cmd=":colorscheme nordic<CR>" ;;
    nordic)                cmd=":colorscheme nordic<CR>" ;;
    kanagawa-wave)         cmd=":colorscheme kanagawa-wave<CR>" ;;
    kanagawa-dragon)       cmd=":colorscheme kanagawa-dragon<CR>" ;;
    everforest-hard)       cmd=":let g:everforest_background='hard'<CR>:set background=dark<CR>:colorscheme everforest<CR>" ;;
    everforest-medium)     cmd=":let g:everforest_background='medium'<CR>:set background=dark<CR>:colorscheme everforest<CR>" ;;
    everforest-soft)       cmd=":let g:everforest_background='soft'<CR>:set background=dark<CR>:colorscheme everforest<CR>" ;;
    darkearth)             cmd=":colorscheme darkearth<CR>" ;;
    tokyo-night)           cmd=":colorscheme tokyonight-night<CR>" ;;
    tokyonight-storm)      cmd=":colorscheme tokyonight-storm<CR>" ;;
    tokyonight-moon)       cmd=":colorscheme tokyonight-moon<CR>" ;;
    *) return ;;
    esac
    for sock in /tmp/nvim*.sock(N) /tmp/nvim-*.sock(N) "${TMPDIR}nvim.${USER}"/**/*.0(N); do
        [[ -S "$sock" ]] || continue
        nvim --server "$sock" --remote-send "$cmd" 2>/dev/null
    done
}

# Update themery state file so nvim picks correct theme on next launch
nvim_save_state() {
    local colorscheme="$1"
    local before_code="$2"
    [[ -z "$colorscheme" ]] && return
    [[ ! -f "$THEMERY_STATE" ]] && return

    python3 - "$THEMERY_STATE" "$colorscheme" "$before_code" <<'PYEOF'
import json, sys
path, colorscheme, before_code = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f:
    state = json.load(f)
state['colorscheme'] = colorscheme
state['beforeCode'] = before_code.replace('\\n', '\n')
with open(path, 'w') as f:
    json.dump(state, f)
PYEOF
}

# Parse toml color file and push all values via alacritty msg config (live reload)
alacritty_apply_colors() {
    local toml_file="$1"
    [[ -f "$toml_file" ]] || return

    local args=()
    local section=""
    while IFS= read -r line; do
        # Track current [section]
        if [[ "$line" =~ '^\[(.+)\]$' ]]; then
            section="${match[1]}"
            continue
        fi
        # Parse key = "value" lines
        if [[ "$line" =~ '^([a-z]+)[[:space:]]*=[[:space:]]*"(#[0-9a-fA-F]+)"' ]]; then
            local key="${match[1]}"
            local val="${match[2]}"
            args+=("${section}.${key}=\"${val}\"")
        fi
    done < "$toml_file"

    (( ${#args} > 0 )) && alacritty msg config "${args[@]}" 2>/dev/null
}

apply_theme() {
    local theme="$1"
    local alacritty_file="$ALACRITTY_THEMES_DIR/${theme}.toml"
    local tmux_file="$TMUX_THEMES_DIR/${theme}.conf"

    if [[ -f "$alacritty_file" ]]; then
        cp "$alacritty_file" "$ALACRITTY_CURRENT"
        alacritty_apply_colors "$alacritty_file"
    fi
    if [[ -f "$tmux_file" ]] && [[ -n "$TMUX" ]]; then
        tmux source-file "$tmux_file"
    fi

    nvim_apply_theme "$theme"
}

save_theme() {
    local theme="$1"
    mkdir -p "$(dirname "$CURRENT_THEME_FILE")"
    echo "$theme" > "$CURRENT_THEME_FILE"

    local tmux_file="$TMUX_THEMES_DIR/${theme}.conf"
    [[ -f "$tmux_file" ]] && cp "$tmux_file" "$TMUX_CURRENT"

    local nvim_info
    nvim_info=($(nvim_theme_for "$theme"))
    local colorscheme="${nvim_info[1]}"
    local before_code="${nvim_info[2]}"
    nvim_save_state "$colorscheme" "$before_code"
}

# Read current theme for restore-on-cancel
original_theme=""
[[ -f "$CURRENT_THEME_FILE" ]] && original_theme="$(cat "$CURRENT_THEME_FILE")"

# Build theme list (names without extension, sorted)
themes=()
for f in "$ALACRITTY_THEMES_DIR"/*.toml; do
    [[ -f "$f" ]] || continue
    name="${f:t:r}"
    themes+=("$name")
done

if (( ${#themes} == 0 )); then
    echo "No themes found in $ALACRITTY_THEMES_DIR" >&2
    exit 1
fi

# Export for use in preview subshell
export ALACRITTY_THEMES_DIR TMUX_THEMES_DIR ALACRITTY_CURRENT TMUX_CURRENT

# Build sorted list with current theme first so it starts highlighted
theme_list=$(printf '%s\n' "${themes[@]}" | sort)
if [[ -n "$original_theme" ]]; then
    theme_list=$(printf '%s\n' "$original_theme"; printf '%s\n' "${themes[@]}" | sort | grep -v "^${original_theme}$")
fi

# Run fzf - preview applies theme live, selection confirms, ESC cancels
chosen=$(printf '%s\n' "$theme_list" | fzf \
    --prompt "theme > " \
    --border rounded \
    --border-label " terminal-theme-picker " \
    --height 100% \
    --layout reverse \
    --preview "$HOME/code/scripts/terminal-theme-picker-preview {}" \
    --preview-window "right:40%:wrap" \
    --bind "esc:abort" \
    --bind "ctrl-c:abort")

exit_code=$?

if [[ $exit_code -eq 0 ]] && [[ -n "$chosen" ]]; then
    apply_theme "$chosen"
    save_theme "$chosen"
else
    if [[ -n "$original_theme" ]]; then
        sleep 0.1
        apply_theme "$original_theme"
    fi
fi

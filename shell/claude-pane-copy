#!/usr/bin/env zsh
# NAME
#   claude-pane-copy - browse and copy messages from a Claude pane
#
# SYNOPSIS
#   claude-pane-copy PANE_ID
#
# DESCRIPTION
#   Parses the scrollback of a Claude Code session pane and presents
#   all user messages and assistant responses in fzf. Select one to
#   copy it to the clipboard.
#
# ARGUMENTS
#   PANE_ID   tmux pane ID (e.g. %22)
#
# EXAMPLES
#   claude-pane-copy %22

target_pane="$1"

if [[ -z "$target_pane" ]]; then
  echo "Usage: claude-pane-copy PANE_ID"
  exit 1
fi

tmp=$(mktemp /tmp/claude-pane-XXXXXX)
trap "rm -f $tmp" EXIT

# Capture scrollback, stripping the Claude Code input box UI at the bottom
# The input box is bracketed by ─────... separator lines; drop from the last one up
raw=$(tmux capture-pane -p -t "$target_pane" -S -32767 2>/dev/null \
  | awk '/^─{10,}$/ { prev_sep = last_sep; last_sep = NR } { lines[NR] = $0 }
     END { for (i=1; i < prev_sep; i++) print lines[i] }')

if [[ -z "$raw" ]]; then
  echo "Could not capture pane: $target_pane"
  exit 1
fi

# ── Parse into records ───────────────────────────────────────────────────────
# Segments the scrollback by ❯ (user) and ⏺ (assistant) prefix lines.
# Each record written to $tmp as: ROLE\tCONTENT  (newlines in content -> \x01)

echo "$raw" | awk '
  function flush(    content) {
    if (role == "") return
    content = buf
    gsub(/\n$/, "", content)       # trim trailing newline
    gsub(/\n/, "\x01", content)    # encode newlines
    print role "\t" content >> "'"$tmp"'"
    buf = ""
    role = ""
  }
  /^❯ |^> / {
    flush()
    role = "user"
    line = $0; sub(/^❯ /, "", line); sub(/^> /, "", line)
    buf = line "\n"
    next
  }
  /^⏺ / {
    if (role == "user") flush()
    line = $0; sub(/^⏺ /, "", line)
    if (role == "assistant") {
      buf = buf line "\n"
    } else {
      role = "assistant"
      buf = line "\n"
    }
    next
  }
  role != "" {
    buf = buf $0 "\n"
  }
  END { flush() }
'

if [[ ! -s "$tmp" ]]; then
  echo "No messages found in pane $target_pane"
  read -k1 "?Press any key to exit"
  exit 1
fi

# ── Build fzf input ──────────────────────────────────────────────────────────
# Format: INDEX TAB LABEL  FIRST_LINE

total=$(wc -l < "$tmp")
fzf_input=$(tac "$tmp" | awk -F'\t' -v total="$total" '
  {
    role = $1
    encoded = $2
    content = encoded
    gsub(/\x01/, "\n", content)
    n = split(content, lines, "\n")
    first = lines[1]
    if (length(first) > 120) first = substr(first, 1, 120)
    if (role == "user") {
      label = "\033[38;2;215;153;33m[YOU]   \033[0m"
      colored_first = "\033[38;2;215;153;33m" first "\033[0m"
    } else {
      label = "\033[38;2;131;165;152m[CLAUDE]\033[0m"
      colored_first = "\033[38;2;131;165;152m" first "\033[0m"
    }
    printf "%d\t%s  %s\n", total-NR, label, colored_first
  }
')

if [[ -z "$fzf_input" ]]; then
  echo "No messages to display"
  exit 1
fi

# ── fzf picker ───────────────────────────────────────────────────────────────

selected=$(echo "$fzf_input" \
  | fzf \
      --no-sort \
      --ansi \
      --border=rounded \
      --border-label=" claude pane " \
      --prompt="  message: " \
      --header="  enter to copy   esc to quit" \
      --delimiter=$'\t' \
      --with-nth=2 \
      --preview="
        idx=\$(echo {} | cut -f1)
        awk -F'\t' -v i=\"\$idx\" 'NR==i+1 {
          gsub(/\x01/, \"\n\", \$2)
          printf \"%s\", \$2
        }' '$tmp' \
        | bat --color=always --plain --language=markdown --theme=gruvbox-dark 2>/dev/null
      " \
      --preview-window="right:60%:wrap" \
      --color="hl:bold:#fb4934,hl+:bold:#fb4934")

[[ -z "$selected" ]] && exit 0

# ── Copy to clipboard ────────────────────────────────────────────────────────

idx=$(echo "$selected" | cut -f1)
awk -F'\t' -v i="$idx" 'NR==i+1 { gsub(/\x01/, "\n", $2); printf "%s", $2 }' "$tmp" \
  | pbcopy

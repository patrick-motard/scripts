#!/usr/bin/env zsh
# NAME
#   claude-pane-copy - browse and copy messages from a Claude pane
#
# SYNOPSIS
#   claude-pane-copy [PANE_ID]
#
# DESCRIPTION
#   Parses the scrollback of a Claude Code session pane and presents
#   all user messages and assistant responses in fzf. Select one to
#   copy it to the clipboard.
#
#   If no pane is specified, targets the other pane in the current window.
#   If there are multiple other panes, presents a pane picker first.
#
# ARGUMENTS
#   PANE_ID   Optional tmux pane target (e.g. chezmoi:2.0)
#
# EXAMPLES
#   claude-pane-copy
#   claude-pane-copy chezmoi:2.0

target_pane="$1"

if [[ -z "$target_pane" ]]; then
  echo "Usage: claude-pane-copy PANE_ID"
  exit 1
fi

# ── Capture and parse ────────────────────────────────────────────────────────

raw=$(tmux capture-pane -p -t "$target_pane" -S -32767 2>/dev/null)

if [[ -z "$raw" ]]; then
  echo "Could not capture pane: $target_pane"
  exit 1
fi

# Parse into tab-separated records: ROLE\tFIRST_LINE\tFULL_CONTENT
# Written to a temp file so fzf preview can read it by line number
tmp=$(mktemp /tmp/claude-pane-XXXXXX)
trap "rm -f $tmp" EXIT

python3 - "$tmp" <<'PYEOF'
import sys, re

tmp_file = sys.argv[1]
raw = sys.stdin.read()
lines = raw.splitlines()

messages = []
current_role = None
current_lines = []

def flush(role, lines):
    content = '\n'.join(lines).strip()
    if content:
        messages.append((role, content))

for line in lines:
    if line.startswith('❯ ') or line.startswith('> '):
        if current_role:
            flush(current_role, current_lines)
        current_role = 'user'
        current_lines = [line[2:].strip()]
    elif line.startswith('⏺ '):
        if current_role == 'user':
            flush(current_role, current_lines)
            current_role = 'assistant'
            current_lines = [line[2:].strip()]
        elif current_role == 'assistant':
            current_lines.append(line[2:].strip())
        else:
            current_role = 'assistant'
            current_lines = [line[2:].strip()]
    elif current_role:
        current_lines.append(line)

if current_role:
    flush(current_role, current_lines)

# Write records to temp file: role TAB first_line TAB full_content (newlines -> \x00)
with open(tmp_file, 'w') as f:
    for role, content in messages:
        first_line = content.split('\n')[0][:120]
        # encode newlines as \x00 so the record stays on one line
        encoded = content.replace('\n', '\x00')
        f.write(f"{role}\t{first_line}\t{encoded}\n")

# Print fzf input lines: "  [USER]  first_line" or "  [CLAUDE]  first_line"
for role, content in messages:
    first_line = content.split('\n')[0][:120]
    label = '[YOU]   ' if role == 'user' else '[CLAUDE]'
    print(f"{label}  {first_line}")
PYEOF < <(echo "$raw")

if [[ ! -s "$tmp" ]]; then
  echo "No messages found in pane $target_pane"
  exit 1
fi

# ── fzf picker ───────────────────────────────────────────────────────────────

selected_line=$(
  python3 -c "
import sys
tmp = open('$tmp').readlines()
for i, line in enumerate(tmp):
    role, first, _ = line.split('\t', 2)
    label = '[YOU]   ' if role == 'user' else '[CLAUDE]'
    print(f'{i}\t{label}  {first.strip()}')
" \
  | fzf \
      --no-sort \
      --ansi \
      --border=rounded \
      --border-label=" claude pane " \
      --prompt="  message: " \
      --header="  enter to copy   esc to quit" \
      --delimiter=$'\t' \
      --with-nth=2 \
      --preview="
        idx=\$(echo {} | cut -f1)
        python3 -c \"
import sys
lines = open('$tmp').readlines()
idx = int(sys.argv[1])
role, first, encoded = lines[idx].split('\t', 2)
content = encoded.replace('\x00', '\n')
print(content)
\" \"\$idx\" | bat --color=always --plain --language=markdown --theme=gruvbox-dark 2>/dev/null
      " \
      --preview-window="right:60%:wrap"
)

[[ -z "$selected_line" ]] && exit 0

# ── Copy to clipboard ────────────────────────────────────────────────────────

idx=$(echo "$selected_line" | cut -f1)
python3 -c "
import sys
lines = open('$tmp').readlines()
idx = int(sys.argv[1])
role, first, encoded = lines[idx].split('\t', 2)
content = encoded.strip().replace('\x00', '\n')
sys.stdout.write(content)
" "$idx" | pbcopy

#!/usr/bin/env zsh
# NAME
#   cmd-history-browse - interactive shell command history browser
#
# SYNOPSIS
#   cmd-history-browse [--mode MODE]
#
# DESCRIPTION
#   Opens tv in the terminal to browse structured shell command history.
#   If no mode is given, presents an fzf mode selector first.
#   The selected entry is copied to the clipboard.
#
#   Requires cmd-history-source and cmd-history-preview scripts in the
#   same directory, and a populated history log at:
#     ~/.local/share/cmd-history/history.jsonl
#
#   To populate the log, source cmd-history-logger.zsh in your .zshrc.
#   To enable output capture, run: cmd-capture-on
#
# ARGUMENTS
#   --mode    Skip the mode selector and use this mode directly.
#             Modes: cmd | dir-cmd | output | cmd-output | all
#
# EXAMPLES
#   cmd-history-browse
#   cmd-history-browse --mode cmd

usage="cmd-history-browse [--mode MODE]"

mode=""
script_dir="${0:A:h}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode) mode=$2; shift ;;
    -h|--help) echo "$usage"; exit 0 ;;
    *) break ;;
  esac
  shift
done

if [[ -z "$mode" ]]; then
  mode=$(printf 'dir-cmd\ncmd\noutput\ncmd-output\nall' \
    | fzf \
        --prompt="  mode: " \
        --header="select history view  (ctrl-c to cancel)" \
        --height=40% \
        --border=rounded \
        --border-label=" cmd-history " \
        --no-sort)
  [[ -z "$mode" ]] && exit 0
fi

# Copy helper: pbcopy on macOS, xclip/xsel on Linux
copy_cmd="pbcopy"
if ! command -v pbcopy >/dev/null 2>&1; then
  if command -v xclip >/dev/null 2>&1; then
    copy_cmd="xclip -selection clipboard"
  elif command -v xsel >/dev/null 2>&1; then
    copy_cmd="xsel --clipboard --input"
  else
    copy_cmd="cat"
  fi
fi

# Extract the command portion from the selected line for copying.
# The copy action receives the raw formatted line; we strip the mode-specific
# prefix to get just the command text.
extract_cmd="${script_dir}/cmd-history-extract"

tv cmd-history \
  --source-command "${script_dir}/cmd-history-source --mode ${mode}"

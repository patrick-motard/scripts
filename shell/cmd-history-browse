#!/usr/bin/env zsh
# NAME
#   cmd-history-browse - interactive shell command history browser
#
# SYNOPSIS
#   cmd-history-browse [--mode MODE]
#
# DESCRIPTION
#   Opens tv in the terminal to browse structured shell command history.
#   If no mode is given, presents an fzf mode selector first.
#   The selected entry is copied to the clipboard.
#
#   Requires cmd-history-source and cmd-history-preview scripts in the
#   same directory, and a populated history log at:
#     ~/.local/share/cmd-history/history.jsonl
#
#   To populate the log, source cmd-history-logger.zsh in your .zshrc.
#   To enable output capture, run: cmd-capture-on
#
# ARGUMENTS
#   --mode    Skip the mode selector and use this mode directly.
#             Modes: cmd | dir-cmd | output | cmd-output | all
#
# EXAMPLES
#   cmd-history-browse
#   cmd-history-browse --mode cmd

usage="cmd-history-browse [--mode MODE]"

mode=""
script_dir="${0:A:h}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode) mode=$2; shift ;;
    -h|--help) echo "$usage"; exit 0 ;;
    *) break ;;
  esac
  shift
done

mode="${mode:-dir-cmd}"

tv cmd-history \
  --source-command "${script_dir}/cmd-history-source --mode ${mode}"

#!/usr/bin/env bash

# Tmux launcher script for development environment with multiple panes
# TODO: Fix race condition. On a relaunch, the script may see that the app pod is ready
# and try to start the app before all containers are fully initialized.

# TODO: Console starts at the same time as the app server. This means it doesn't pick up
# local code changes. Running reload! in the console fixes this, except for dependency
# injection registration. Either make reload! include those, or make the console start
# after the app server is ready.

# TODO: Convert this to a ruby script.

wait_for_app() {
    # Wait for kubernetes pod to be ready
    # Configure SERVICE_NAME environment variable for your service
    local service_name="${SERVICE_NAME:-app-server}"
    for i in {1..999}
    do
      kubectl get pods -l role=app-server,service=$service_name | \
        awk 'FNR == 2 {rc=($2=="1/1")}; END { exit !rc }' \
        && break \
        || echo "not ready yet"; sleep 1
    done
}

# Configuration - adjust these for your environment
SESSION_NAME="${SESSION_NAME:-dev-session}"
window=${SESSION_NAME}:0
launcher_pane=${window}.0
app_pane=${window}.1
console_pane=${window}.2

# TODO: Fix this not working correctly when the session is already running.
# Configuration - adjust these paths and commands for your environment
PROJECT_DIR="${PROJECT_DIR:-~/code/my-project}"
LAUNCHER_CMD="${LAUNCHER_CMD:-make launch}"
DEVSPACE_MODE="${DEVSPACE_MODE:-app-server}"
CONSOLE_CMD="${CONSOLE_CMD:-devspace run rails-console-app-server}"

tmux send-keys -t "${launcher_pane}" C-c "cd ${PROJECT_DIR} && ${LAUNCHER_CMD}" C-m && \
  wait_for_app && \
  tmux send-keys -t "${app_pane}" C-c "cd ${PROJECT_DIR} && devspace dev --mode ${DEVSPACE_MODE}" C-m && \
  tmux send-keys -t "${console_pane}" C-c "cd ${PROJECT_DIR} && ${CONSOLE_CMD}" C-m

